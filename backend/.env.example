# ─────────────────────────────────────────────────────────────
# PlaceMates Backend — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your actual values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ── Auth — Google OAuth ──────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Auth — JWT ───────────────────────────────────────────────
JWT_SECRET=your_jwt_secret

# ── Auth — GitHub OAuth ──────────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ── Gemini (optional — only if using AI features) ────────────
GEMINI_API_KEY=your_gemini_api_key

# ── Encryption ───────────────────────────────────────────────
TOKEN_ENCRYPTION_KEY=your_64_char_hex_string

# ── Cloudinary (required for image uploads) ──────────────────
# Sign up at https://cloudinary.com and get credentials from Dashboard > Settings
CLOUDINARY_CLOUD_NAME=dkaia9lne
CLOUDINARY_API_KEY=498293388883774
CLOUDINARY_API_SECRET=WYwNCN9TwHhhK9uPUsGkmWFSXQo

# ── n8n Workflow Integration ─────────────────────────────────
# Webhook URL that triggers the n8n job matching workflow
N8N_WEBHOOK_URL=https://placeholder-n8n/webhook/n8n/match-jobs
# Shared secret for authenticating n8n callback requests
N8N_WEBHOOK_SECRET=your_n8n_webhook_secret

# ── Optional overrides ──────────────────────────────────────
# PORT=5000
# NODE_ENV=development
# BACKEND_URL=http://localhost:5000
# FRONTEND_URL=http://localhost:3000
