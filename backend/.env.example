# ─────────────────────────────────────────────────────────────
# PlaceMates Backend — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your actual values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ── Auth — Google OAuth ──────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Auth — JWT ───────────────────────────────────────────────
JWT_SECRET=your_jwt_secret

# ── Auth — GitHub OAuth ──────────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ── Gemini (optional — only if using AI features) ────────────
GEMINI_API_KEY=your_gemini_api_key

# ── Encryption ───────────────────────────────────────────────
TOKEN_ENCRYPTION_KEY=your_64_char_hex_string

# ── Cloudinary (required for resume PDF uploads) ─────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── n8n Workflow Integration ─────────────────────────────────
N8N_WEBHOOK_URL=https://placeholder-n8n/webhook/n8n/match-jobs
N8N_WEBHOOK_SECRET=your_n8n_webhook_secret

# ── Internal API Key (shared with n8n) ───────────────────────
INTERNAL_API_KEY=your_internal_api_key

# ── LLM Provider (for RAG resume generation) ─────────────────
# Options: groq | ollama | none
LLM_PROVIDER=groq
LLM_API_KEY=your_groq_api_key
LLM_MODEL=llama-3.3-70b-versatile
# OLLAMA_BASE_URL=http://localhost:11434

# ── Embedding Service (Python microservice) ──────────────────
EMBEDDING_SERVICE_URL=http://localhost:8100
SEMANTIC_MATCH_THRESHOLD=0.35
RAG_MAX_ITERATIONS=3
RAG_ATS_THRESHOLD=75

# ── Optional overrides ──────────────────────────────────────
# PORT=5000
# NODE_ENV=development
# BACKEND_URL=http://localhost:5000
# FRONTEND_URL=http://localhost:3000

