generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────────
// EXISTING MODELS (preserved for backward compatibility)
// ────────────────────────────────────────────────────────────

model UserAuth {
  id        String   @id @default(uuid())
  email     String   @unique
  profile   UserProfile?
  oauth     OAuthAccount[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Onboarding & connection tracking ──
  githubConnected  Boolean @default(false)
  linkedinImported Boolean @default(false)
  onboardingStage  String  @default("new")
}

model UserProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      UserAuth @relation(fields: [userId], references: [id])
  name         String?
  avatarUrl    String?
}

model OAuthAccount {
  id              String   @id @default(uuid())
  userId          String
  provider        String
  providerUserId  String
  accessToken     String?
  user            UserAuth @relation(fields: [userId], references: [id])

  @@unique([provider, providerUserId])
}

