generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────

model UserAuth {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Connection state
  githubConnected   Boolean @default(false)
  githubAccessToken String?
  githubLogin       String? // resolved on first GitHub sync
  linkedinImported  Boolean @default(false)
  linkedinZipPath   String? // path to uploaded ZIP for processing
  onboardingStage   String  @default("new")

  // Relations
  profile        UserProfile?
  oauth          OAuthAccount[]
  projects       Project[]
  skills         Skill[]
  experiences    Experience[]
  educations     Education[]
  awards         Award[]
  certifications Certification[]
  summary        UserSummary?
  portfolio      UserPortfolio?
}

model UserProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      UserAuth @relation(fields: [userId], references: [id])
  name      String?
  avatarUrl String?
}

model OAuthAccount {
  id             String   @id @default(uuid())
  userId         String
  provider       String
  providerUserId String
  accessToken    String?
  user           UserAuth @relation(fields: [userId], references: [id])

  @@unique([provider, providerUserId])
}

// ─────────────────────────────────────────────────────────────
// GITHUB PIPELINE → Projects
// ─────────────────────────────────────────────────────────────

model Project {
  id     String   @id @default(uuid())
  userId String
  user   UserAuth @relation(fields: [userId], references: [id])

  name          String
  repoUrl       String
  domain        String?  // Frontend | Backend | ML | DevOps | Mobile
  projectType   String   // "solo" | "collaborative"
  collaborators Int      @default(1)
  techStack     String[] // ordered by usage

  // Two-stage bullets:
  //   baseBullets  → AI-generated (no user metrics yet)
  //   finalBullets → metrics injected after quiz
  // description = denormalized single string for resume/portfolio display
  baseBullets  String[]
  finalBullets String[]
  description  String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, repoUrl]) // enables idempotent upsert on re-analysis
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────
// SHARED → Skills  (GitHub primary + LinkedIn supplementary)
// ─────────────────────────────────────────────────────────────

model Skill {
  id     String   @id @default(uuid())
  userId String
  user   UserAuth @relation(fields: [userId], references: [id])

  name   String  // normalized, e.g. "React", "Node.js", "Python"
  domain String? // Frontend | Backend | ML | DevOps | Mobile | Other
  source String  // "github" | "linkedin" | "both"

  @@unique([userId, name])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────
// LINKEDIN PIPELINE → Experience, Education, Award, Certification
// ─────────────────────────────────────────────────────────────

model Experience {
  id     String   @id @default(uuid())
  userId String
  user   UserAuth @relation(fields: [userId], references: [id])

  role        String
  company     String
  startDate   String?  // "Jan 2022" — kept as LinkedIn string
  endDate     String?  // null = present
  description String?  @db.Text // AI-refined, resume-ready

  @@index([userId])
}

model Education {
  id     String   @id @default(uuid())
  userId String
  user   UserAuth @relation(fields: [userId], references: [id])

  institution String
  degree      String?
  field       String?
  startDate   String?
  endDate     String?
  gpa         String?

  @@index([userId])
}

model Award {
  id     String   @id @default(uuid())
  userId String
  user   UserAuth @relation(fields: [userId], references: [id])

  title       String
  description String? @db.Text
  issuedAt    String?

  @@index([userId])
}

model Certification {
  id     String   @id @default(uuid())
  userId String
  user   UserAuth @relation(fields: [userId], references: [id])

  name     String
  issuer   String?
  issuedAt String?

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────
// COMBINED OUTPUT → Summary, Portfolio
// ─────────────────────────────────────────────────────────────

model UserSummary {
  id     String   @id @default(uuid())
  userId String   @unique
  user   UserAuth @relation(fields: [userId], references: [id])

  summaryText   String  @db.Text
  primaryDomain String? // dominant domain across both pipelines

  updatedAt DateTime @updatedAt
}

model UserPortfolio {
  id     String   @id @default(uuid())
  userId String   @unique
  user   UserAuth @relation(fields: [userId], references: [id])

  publicEmail   String
  githubUrl     String?
  linkedinUrl   String?
  websiteUrl    String?
  portfolioSlug String   @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
